  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '\u2022<indent=1em><b>Parks:</b> Each park earns <b>2 points per distinct
    zone</b> it touches.</indent>


    \u2022<indent=1em><b>Schools:</b> Each school
    scores <b>+2 per residential building</b> in the largest adjacent residential
    zone. Only one school can claim any given zone.</indent>


    \u2022<indent=1em><b>Stars:</b>
    Each star rewards a point. Collected during play by selecting double-rolls.</indent>


    \u2022<indent=1em><b>Deductions:</b>
    At game end, every empty non-river tile costs 1 point. Wildcard costs are also
    subtracted.</indent>'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
