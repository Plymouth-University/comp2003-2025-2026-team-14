      m_Calls: []
  m_text: "<b>Auto-reroll:</b> If all 3 shape dice (or all 3 building dice) land
    the same, those dice re-roll automatically. \n\n<b>Doubles = Stars:</b> If any
    face appears twice across the pool, you can earn a star by picking it. One star
    for matching a shape double, one for matching a building double. Each star is
    +1 point.\n\n<b>Deterministic Dice:</b> In multiplayer, all players receives
    the same dice roll"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
