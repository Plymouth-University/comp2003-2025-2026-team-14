  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Same-type buildings that are either <b>Industrial, Residential or Commercial</b>
    and touch edge-to-edge form a <b>zone</b>. \nEach zone scores based on how many
    <b>different shapes</b> are in it.\n\n<i>Pro tip: the more shape variety you
    squeeze into a zone, the better.</i>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
