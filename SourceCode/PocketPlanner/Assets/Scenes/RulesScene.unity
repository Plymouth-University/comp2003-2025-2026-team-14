  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '<size=38><b>Always true:</b></size>

    \u2022<indent=1em>The shape must
    fit entirely within the grid.</indent>

    \u2022<indent=1em>It can''t overlap
    the river or another building.</indent>


    <size=38><b>Turn 1:</b></size>

    \u2022<indent=1em>Your
    shape <b>must cover your chosen starting position</b>.</indent>


    <size=38><b>Turn
    2 onwards:</b></size>

    \u2022<indent=1em>Your shape must touch an existing
    building <b>edge-to-edge</b> (up, down, left, or right - diagonals don''t count).</indent>


    <size=38><b>Water
    Die (Special):</b></size>

    \u2022<indent=1em>If you pick the Water die, you
    choose any building type you want.</indent>

    \u2022<indent=1em>Instead of
    touching a building, it must touch a river tile.</indent>

    \u2022<indent=1em>This
    bypasses the normal adjacency rules.</indent>'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
